FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
API_TOKEN=your-secret-token-here
NODE_ENV=development

# ── Daily Report ────────────────────────────────────
# Group chat ID to receive the 07:00 AI daily digest. Leave blank to disable.
DAILY_REPORT_CHAT_ID=
# Wiki doc token where the daemon appends each day's report (append-top).
DAILY_REPORT_WIKI_TOKEN=
# Cron expression (defaults to 07:00 daily).
DAILY_REPORT_CRON=0 7 * * *
# Timezone for the cron schedule.
DAILY_REPORT_TZ=Asia/Shanghai
